generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String        @id @default(cuid())
  discordId       String        @unique @map("discord_id")
  username        String
  displayName     String?       @map("display_name")
  affinity        Int           @default(20)
  mood            String        @default("neutro")
  xp              Int           @default(0)
  tags            String[]      @default([])
  lastInteraction DateTime      @default(now()) @map("last_interaction")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  interactions    Interaction[]
  memory          UserMemory?
  facts           UserFact[]
  questionsAsked  UserQuestion[]

  @@map("users")
  @@index([discordId])
  @@index([lastInteraction])
}

model UserQuestion {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  questionKey String    @map("question_key")
  askedAt     DateTime  @default(now()) @map("asked_at")
  answeredAt  DateTime? @map("answered_at")

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, questionKey])
  @@map("user_questions")
  @@index([userId])
}

model UserMemory {
  id            String   @id @default(cuid())
  userId        String   @unique @map("user_id")
  summary       String   @default("")
  lastUpdatedAt DateTime @default(now()) @map("last_updated_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_memory")
}

model UserFact {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  fact       String
  confidence Float    @default(0.5)
  lastSeenAt DateTime @default(now()) @map("last_seen_at")
  createdAt  DateTime @default(now()) @map("created_at")

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_facts")
  @@index([userId])
  @@index([lastSeenAt])
}

model Interaction {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  guildId   String?  @map("guild_id")
  channelId String?  @map("channel_id")
  type      String
  message   String?
  response  String?
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("interactions")
  @@index([userId, createdAt])
  @@index([guildId, createdAt])
}

model GuildConfig {
  id            String   @id @default(cuid())
  guildId       String   @unique @map("guild_id")
  casinhaName   String   @default("Casinha do Xeréu") @map("casinha_name")
  volume        Float    @default(1.0)
  audioCooldown Int      @default(5) @map("audio_cooldown")
  aiEnabled     Boolean  @default(true) @map("ai_enabled")
  humorLevel    Int      @default(5) @map("humor_level")
  leashOwnerId  String?  @map("leash_owner_id")
  language      String   @default("pt-BR")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("guild_config")
  @@index([guildId])
}

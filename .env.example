# Discord
# Obtenha seu token em: https://discord.com/developers/applications
DISCORD_TOKEN=seu_token_aqui
DISCORD_CLIENT_ID=seu_client_id_aqui

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=300
OPENAI_TEMPERATURE=0.85

# Postgres (consumido pelo docker-compose e Prisma)
# Usamos porta 5433 por padrão pra não conflitar com Postgres do host
POSTGRES_USER=xareu
POSTGRES_PASSWORD=xareu
POSTGRES_DB=xareu
POSTGRES_PORT=5434
DATABASE_URL=postgresql://xareu:xareu@localhost:5434/xareu

# Redis (porta 6381 por padrão, mesma razão)
REDIS_PORT=6381
REDIS_URL=redis://localhost:6381

# Logger
LOG_LEVEL=info

# Comportamento do Xaréu
AFFINITY_DECAY_PER_DAY=2
AFFINITY_GAIN_PER_INTERACTION=3
AI_CONTEXT_WINDOW=10
AI_RATE_LIMIT_PER_MINUTE=10
